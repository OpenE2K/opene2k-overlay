2) Speed of security channel (with openssh-9.1p1, fast test - 10MB transfer only):

  for i in `ssh -Q cipher`
  do
    dd if=/dev/zero bs=1M count=10 2> /dev/null \
    | /usr/bin/ssh -c $i root@localhost "(/usr/bin/time -p cat) > /dev/null" 2>&1 \
    | grep real | tr , . | awk '{print "'$i': "10 / $2" MB/s" }'
  done

