+            (((u64)Te0[(t3a >>  8) & 0xff] & 0x0000ff00) <<  8) ^
+            ( (u64)Te1[(t0a      ) & 0xff] << 24) ^
+            last_key1;
+        s2a =
+            ( (u64)Te2[(t2a >> 24)       ] >> 24) ^
+            (((u64)Te3[(t3a >> 16) & 0xff] & 0x00ff0000) >>  8) ^
+            (((u64)Te0[(t0a >>  8) & 0xff] & 0x0000ff00) <<  8) ^
+            ( (u64)Te1[(t1a      ) & 0xff] << 24) ^
+            last_key2;
+        s3a =
+            ( (u64)Te2[(t3a >> 24)       ] >> 24) ^
+            (((u64)Te3[(t0a >> 16) & 0xff] & 0x00ff0000) >>  8) ^
+            (((u64)Te0[(t1a >>  8) & 0xff] & 0x0000ff00) <<  8) ^
+            ( (u64)Te1[(t2a      ) & 0xff] << 24) ^
+            last_key3;
+
+        output[0] = input[0] ^ s0a;
+        output[1] = input[1] ^ s1a;
+        output[2] = input[2] ^ s2a;
+        output[3] = input[3] ^ s3a;
+
+        input += 4;
+        output += 4;
+
+        ivec_w3a++;
+    }
+
+}
