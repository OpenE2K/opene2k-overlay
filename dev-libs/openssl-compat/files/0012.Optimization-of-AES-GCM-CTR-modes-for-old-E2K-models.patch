+    u64 s0b, s1b, s2b, s3b, t0b, t1b, t2b, t3b;
+    u64 r1t0, r1t1, r1t2, r1t3;
+
+
+    /* round 1a: */
+    s0a = ivec_w0_xor_rk0;
+    s1a = ivec_w1_xor_rk1;
+    s2a = ivec_w2_xor_rk2;
+
+    r1t0 = (u64)Te0[s0a  >> 24] ^ (u64)Te1[(s1a  >> 16) & 0xff] ^ (u64)Te2[(s2a  >>  8) & 0xff] ^                         (u64)rk[ 4];
+    r1t1 = (u64)Te0[s1a  >> 24] ^ (u64)Te1[(s2a  >> 16) & 0xff] ^                                 (u64)Te3[s0a  & 0xff] ^ (u64)rk[ 5];
+    r1t2 = (u64)Te0[s2a  >> 24] ^                                 (u64)Te2[(s0a  >>  8) & 0xff] ^ (u64)Te3[s1a  & 0xff] ^ (u64)rk[ 6];
+    r1t3 =                        (u64)Te1[(s0a  >> 16) & 0xff] ^ (u64)Te2[(s1a  >>  8) & 0xff] ^ (u64)Te3[s2a  & 0xff] ^ (u64)rk[ 7];
+
