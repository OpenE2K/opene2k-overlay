+        t2a = r1t2 ^ (u64)Te1[(s3a >> 16) & 0xff];
+        t3a = r1t3 ^ (u64)Te0[ s3a >> 24];
+
+        t0b = r1t0 ^ (u64)Te3[ s3b & 0xff];
