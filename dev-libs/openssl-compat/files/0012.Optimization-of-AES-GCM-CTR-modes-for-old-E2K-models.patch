+    const u64 ivec_w1_xor_rk1 = __builtin_bswap32(((u32 *)ivec)[1]) ^ (u64)rk[1];
+    const u64 ivec_w2_xor_rk2 = __builtin_bswap32(((u32 *)ivec)[2]) ^ (u64)rk[2];
+
+    u64 ivec_w3a = __builtin_bswap32(((u32 *)ivec)[3]);
+    u64 ivec_w3b = ivec_w3a + 1;
+
