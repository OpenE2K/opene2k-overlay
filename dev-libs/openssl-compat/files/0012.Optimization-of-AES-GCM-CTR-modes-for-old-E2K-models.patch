+#ifdef __e2k__
+void e2kv2_ctr32_encrypt_blocks_x2(const void *in, void *out,
+                                   size_t blocks, const AES_KEY *key,
+                                   const char *ivec)
+{
+    u32 * __restrict__ input  = (u32 *)in;
+    u32 * __restrict__ output = (u32 *)out;
