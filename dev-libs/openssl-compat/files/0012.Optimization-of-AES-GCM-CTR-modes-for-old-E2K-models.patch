+    const u64 last_key1 = __builtin_bswap32(rk[rounds * 4 + 1]);
+    const u64 last_key2 = __builtin_bswap32(rk[rounds * 4 + 2]);
+    const u64 last_key3 = __builtin_bswap32(rk[rounds * 4 + 3]);
+
