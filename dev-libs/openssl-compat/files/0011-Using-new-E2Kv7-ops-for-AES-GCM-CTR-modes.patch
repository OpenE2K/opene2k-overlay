diff --git a/crypto/modes/gcm128.c b/crypto/modes/gcm128.c
index dca1240..fb70d88 100644
--- a/crypto/modes/gcm128.c
+++ b/crypto/modes/gcm128.c
@@ -11,12 +11,14 @@
 #include "modes_local.h"
 #include <string.h>
 
-#if (defined(__e2k__) && __iset__ >= 6)
+#if defined(__e2k__) && (__iset__ >= 6)
 #define GHASH_ASM    /* Disable generic code */
 
 #include <stdint.h>
 #include <e2kintrin.h>
 
+#include <openssl/aes.h>
+
 static __attribute__ ((__always_inline__)) inline
 __v2di reverse_vector(const __v2di in)
 {
@@ -205,6 +207,125 @@ void gcm_ghash_clmul_e2kv6(u64 Xi[2], const u128 Htable[16],
 
     *(__v2di *)Xi = reverse_vector(x);
 }
+
+#if defined(__e2k__) && (__iset__ >= 7)
+
+static __attribute__ ((__always_inline__)) inline
+__v2di aes_encrypt_e2kv7(const __v2di p, const __v2di enc_key[], const int rounds)
+{
+    __v2di x = p;
+    __v2di z = {0LL, 0LL};
+    __v2di prev_key, last_key;
+
+    x = __builtin_e2k_qpaesltr(__builtin_e2k_qpaesebgn(x, enc_key[0], z), z, z);
+    x = __builtin_e2k_qpaesltr(__builtin_e2k_qpaesebgn(x, enc_key[1], z), z, z);
+    x = __builtin_e2k_qpaesltr(__builtin_e2k_qpaesebgn(x, enc_key[2], z), z, z);
+    x = __builtin_e2k_qpaesltr(__builtin_e2k_qpaesebgn(x, enc_key[3], z), z, z);
+    x = __builtin_e2k_qpaesltr(__builtin_e2k_qpaesebgn(x, enc_key[4], z), z, z);
+    x = __builtin_e2k_qpaesltr(__builtin_e2k_qpaesebgn(x, enc_key[5], z), z, z);
+    x = __builtin_e2k_qpaesltr(__builtin_e2k_qpaesebgn(x, enc_key[6], z), z, z);
+    x = __builtin_e2k_qpaesltr(__builtin_e2k_qpaesebgn(x, enc_key[7], z), z, z);
+    x = __builtin_e2k_qpaesltr(__builtin_e2k_qpaesebgn(x, enc_key[8], z), z, z);
+
+    prev_key = enc_key[9];
+    last_key = enc_key[10];
+    if (rounds >= 12) {
+        x = __builtin_e2k_qpaesltr(__builtin_e2k_qpaesebgn(x, enc_key[9], z), z, z);
+        x = __builtin_e2k_qpaesltr(__builtin_e2k_qpaesebgn(x, enc_key[10], z), z, z);
+        prev_key = enc_key[11];
+        last_key = enc_key[12];
+        if (rounds == 14) {
+            x = __builtin_e2k_qpaesltr(__builtin_e2k_qpaesebgn(x, enc_key[11], z), z, z);
+            x = __builtin_e2k_qpaesltr(__builtin_e2k_qpaesebgn(x, enc_key[12], z), z, z);
+            prev_key = enc_key[13];
+            last_key = enc_key[14];
+        }
+    }
+
+    x = __builtin_e2k_qpaesebgn(x, prev_key, z);
+    return __builtin_e2k_qpxor(x, last_key);
+}
+
+
+static __attribute__ ((__always_inline__)) inline
+__v2di incr(__v2di x)
+{
+    __v2di fmt = __builtin_e2k_qppackdl(0x0001020304050607LL, 0x08090a0b0c0d0e0fLL);
+    x = __builtin_e2k_qppermb(x, x, fmt);
+    x = __builtin_e2k_qpaddd(x, (__v2di){1LL, 0LL});
+    return __builtin_e2k_qppermb(x, x, fmt);
+}
+
+static __attribute__ ((__always_inline__)) inline
+__v2di add4(__v2di x)
+{
+    __v2di fmt = __builtin_e2k_qppackdl(0x0001020304050607LL, 0x08090a0b0c0d0e0fLL);
+    x = __builtin_e2k_qppermb(x, x, fmt);
+    x = __builtin_e2k_qpaddd(x, (__v2di){4LL, 0LL});
+    return __builtin_e2k_qppermb(x, x, fmt);
+}
+
+/** Handles only complete blocks, operates on 32-bit counter and
+ *  does not update *ivec! (see crypto/modes/ctr128.c for details)
+ */
+void e2kv7_ctr32_encrypt_blocks(const void *in, void *out,
+                                size_t blocks, const AES_KEY *aes_key,
+                                const char *ivec)
+{
+    __v2di y0 = *(__v2di *)ivec;
+    __v2di y1 = incr(y0);
+    __v2di y2 = incr(y1);
+    __v2di y3 = incr(y2);
+
+    __v2di * __restrict__ input = (__v2di *)in;
+    __v2di * __restrict__ output = (__v2di *)out;
+
+    __v2di * __restrict__ rd_key = (__v2di *)aes_key->rd_key;
+    const int rounds = aes_key->rounds;
+    int i;
+
+#pragma unroll(1)
+#pragma loop count(1000)
+    while(blocks >= 4)
+    {
+        __v2di m0 = input[0];
+        __v2di m1 = input[1];
+        __v2di m2 = input[2];
+        __v2di m3 = input[3];
+
+        m0 ^= aes_encrypt_e2kv7(y0, rd_key, rounds);
+        m1 ^= aes_encrypt_e2kv7(y1, rd_key, rounds);
+        m2 ^= aes_encrypt_e2kv7(y2, rd_key, rounds);
+        m3 ^= aes_encrypt_e2kv7(y3, rd_key, rounds);
+
+        output[0] = m0;
+        output[1] = m1;
+        output[2] = m2;
+        output[3] = m3;
+
+        y0 = add4(y0);
+        y1 = add4(y1);
+        y2 = add4(y2);
+        y3 = add4(y3);
+
+        input += 4;
+        output += 4;
+        blocks -= 4;
+    }
+
+#pragma loop count(3)
+    for(i=0; i < blocks; i++)
+    {
+        __v2di m = input[i];
+
+        m ^= aes_encrypt_e2kv7(y0, rd_key, rounds);
+        output[i] = m;
+
+        y0 = incr(y0);
+    }
+}
+
+#endif /* For E2Kv7+ only */
 #endif /* For E2Kv6+ only */
 
 
