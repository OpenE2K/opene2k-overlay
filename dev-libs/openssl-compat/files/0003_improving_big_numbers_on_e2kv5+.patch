+BN_ULONG bn_mul_add_words(BN_ULONG *rp, const BN_ULONG *ap, int num,
+                          BN_ULONG w)
+{
+    BN_ULONG c1 = 0;
+    BN_ULONG * __restrict__ rr = rp;
+
+    if (num <= 0)
+        return c1;
+
+#pragma loop count(25)
+    while (num) {
+        mul_add(rr[0], ap[0], w, c1);
+        ap++;
+        rr++;
+        num--;
+    }
+
+    return c1;
+}
+
+BN_ULONG bn_mul_words(BN_ULONG *rp, const BN_ULONG *ap, int num, BN_ULONG w)
+{
+    BN_ULONG c1 = 0;
+    BN_ULONG * __restrict__ rr = rp;
+
+    if (num <= 0)
+        return c1;
+
+#pragma loop count(64)
+    while (num) {
+        mul(rr[0], ap[0], w, c1);
+        ap++;
+        rr++;
+        num--;
+    }
+    return c1;
+}
+
+void bn_sqr_words(BN_ULONG *r, const BN_ULONG *a, int n)
+{
+    BN_ULONG * __restrict__ rr = r;
+
+    if (n <= 0)
+        return;
+
+#pragma loop count(64)
+    while (n) {
+        sqr(rr[0], rr[1], a[0]);
+        a++;
+        rr += 2;
+        n--;
+    }
+}
