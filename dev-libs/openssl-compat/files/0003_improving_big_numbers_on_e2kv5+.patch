+BN_ULONG bn_add_words(BN_ULONG *y, const BN_ULONG *a, const BN_ULONG *b,
+                      int n)
+{
+    BN_ULONG c = 0;
+    BN_ULONG * __restrict__ r = y;
+
+    if (n <= 0)
+        return (BN_ULONG)0;
+
+#pragma loop count(25)
+    while (n) {
+#if __iset__ < 5
+        BN_ULONG l, t = a[0];
+        t = (t + c) & BN_MASK2;
+        c = (t < c);
+        l = (t + b[0]) & BN_MASK2;
+        c += (l < t);
+        r[0] = l;
+#else
+        BN_ULONG q = __builtin_e2k_addcd_c(a[0], b[0], c);
+        r[0] = __builtin_e2k_addcd  (a[0], b[0], c); c = q;
+#endif
+        a++;
+        b++;
+        r++;
+        n--;
+    }
+    return c;
+}
+
+BN_ULONG bn_sub_words(BN_ULONG *y, const BN_ULONG *a, const BN_ULONG *b,
+                      int n)
+{
+    BN_ULONG c = 0;
+    BN_ULONG * __restrict__ r = y;
+
+    if (n <= 0)
+        return (BN_ULONG)0;
+
+#pragma loop count(25)
+    while (n) {
+#if __iset__ < 5
+        BN_ULONG t1 = a[0];
+        BN_ULONG t2 = b[0];
+        r[0] = (t1 - t2 - c) & BN_MASK2;
+        if (t1 != t2)
+            c = (t1 < t2);
+#else
+        BN_ULONG q = __builtin_e2k_subcd_c(a[0], b[0], c);
+        r[0] = __builtin_e2k_subcd  (a[0], b[0], c); c = q;
+#endif
+        a++;
+        b++;
+        r++;
+        n--;
+    }
+    return c;
+}
