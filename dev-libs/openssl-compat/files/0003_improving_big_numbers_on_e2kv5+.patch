+#if __iset__ < 5
+#define mul_add(r,a,w,c) {                  \
+        BN_ULONG high,low,ret,tmp=(a);      \
+        ret =  (r);                         \
+        high=  __builtin_e2k_umulhd(w,tmp); \
+        ret += (c);                         \
+        low =  (w) * tmp;                   \
+        (c) =  (ret<(c))?1:0;               \
+        (c) += high;                        \
+        ret += low;                         \
+        (c) += (ret<low)?1:0;               \
+        (r) =  ret;                         \
+        }
+
+#define mul(r,a,w,c)    {                  \
+        BN_ULONG high,low,ret,ta=(a);      \
+        low =  (w) * ta;                   \
+        high=  __builtin_e2k_umulhd(w,ta); \
+        ret =  low + (c);                  \
+        (c) =  high;                       \
+        (c) += (ret<low)?1:0;              \
+        (r) =  ret;                        \
+        }
+
+#  define sqr(r0,r1,a)    {                   \
+        BN_ULONG tmp=(a);                     \
+        (r0) = tmp * tmp;                     \
+        (r1) = __builtin_e2k_umulhd(tmp,tmp); \
+        }
+
+#else
+
+/* {cout[64],rout[64]} = (rin[64] + cin[64]) + a[64]*w[64] */
+#define mul_add(r,a,w,c) {                      \
+        BN_ULONG high,low,ret,ta=(a),tc=(c),q;  \
+        ret = (r);                              \
+        high= __builtin_e2k_umulhd(w,ta);       \
+        low = (w) * ta;                         \
+        q = __builtin_e2k_addcd_c(ret, tc, 0);  \
+        ret += tc;                              \
+        c = __builtin_e2k_addcd_c(ret, low, 0); \
+        r = ret + low;                          \
+        c += high + q;                          \
+        }
+
+#define mul(r,a,w,c)    {                     \
+        BN_ULONG high,low,q,ta=(a);           \
+        low =  (w) * ta;                      \
+        high=  __builtin_e2k_umulhd(w,ta);    \
+        q = __builtin_e2k_addcd_c(low, c, 0); \
+        r = low + (c);                        \
+        c = high + q;                         \
+        }
+
+#define sqr(r0,r1,a)    {                      \
+        BN_ULONG tmp=(a);                      \
+        (r0) = tmp * tmp;                      \
+        (r1) = __builtin_e2k_umulhd(tmp,tmp);  \
+        }
