2) Speed of security channel

for i in `ssh -Q cipher`
do
  dd if=/dev/zero bs=1M count=10 2> /dev/null \
  | ssh -c $i root@localhost "(time -p cat) > /dev/null" 2>&1 \
  | grep real | tr , . | awk '{print "'$i': "100 / $2" MB/s" }'
done

