 	.size = ARCH_SIZE_64,
 	.endian = ARCH_ENDIAN_LITTLE,
-	.syscall_resolve_name = e2k_syscall_resolve_name,
-	.syscall_resolve_num = e2k_syscall_resolve_num,
+	.syscall_resolve_name = e2k_syscall_resolve_name_munge,
+	.syscall_resolve_name_raw = e2k_syscall_resolve_name,
+	.syscall_resolve_num = e2k_syscall_resolve_num_munge,
+	.syscall_resolve_num_raw = e2k_syscall_resolve_num,
 	.syscall_rewrite = NULL,
