diff -Naur a/src/syscalls-e2k.sh b/src/syscalls-e2k.sh
--- a/src/syscalls-e2k.sh	1970-01-01 03:00:00.000000000 +0300
+++ b/src/syscalls-e2k.sh	2025-02-06 15:44:24.564384310 +0300
@@ -0,0 +1,50 @@
+#!/bin/bash
+
+sys_csv="src/syscalls.csv"
+sys_add="src/syscalls_e2k.txt"
+new_csv="src/syscalls_new.csv"
+new_hdr="src/syscalls_hdr.txt"
+
+awk '/^#define __NR/ {
+  # remove duplicate syscall
+  if ($2 == "__NR_madvise1") next;
+  sub("^__NR_","",$2); print $2 " " $3
+}
+# skip tail
+$2 == "NR_syscalls" { exit }
+' /usr/include/asm/unistd.h > $sys_add
+
+echo "$(head -n1 $sys_csv),e2k" > $new_hdr
+
+cat "$sys_csv" | grep '^[^#].*,' | (
+  while IFS= read str; do
+    name=${str%%,*}
+    val="$(grep "^$name " $sys_add | sed "s/^.* //")"
+    test -z "$val" && val="PNR"
+    echo "$str,$val" >> "$new_csv"
+  done
+)
+
+pnr="$(cat "$sys_csv" | grep -m1 '^[^#].*,')"
+pnr="$(echo ${pnr#*,} | sed 's/[0-9]\+/PNR/g')"
+
+cat "$sys_add" | grep '^[^#].* [0-9]\+' | (
+  while IFS= read str; do
+    name=${str%% *}
+    grep -q "^$name," $sys_csv || { \
+      echo $name,$pnr,${str#* } >> "$new_csv"
+      {
+        echo "#define __PNR_$name -(20000+${str#* })"
+        echo "#ifdef __NR_$name"
+        echo "#define __SNR_$name __NR_$name"
+        echo "#else"
+        echo "#define __SNR_$name __PNR_$name"
+        echo "#endif"
+      } >> include/seccomp-syscalls.h
+    }
+  done
+)
+
+mv -f $new_hdr $sys_csv
+sort -g $new_csv >> $sys_csv
+
