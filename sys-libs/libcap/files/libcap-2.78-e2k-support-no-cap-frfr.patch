 	    __asm__ __volatile__("\npsx_restorer:\n\tmov r8, 139\n\ttrap_s 0\n");
+#elif defined(__e2k__) && defined(__ptr64__)
+            __asm__ __volatile__("\npsx_restorer:\n"
