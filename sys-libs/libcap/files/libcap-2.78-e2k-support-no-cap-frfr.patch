+    || defined(__xtensa__) || defined(__e2k__)
 /* field defined */
 #define _HAS_SA_RESTORER   void *sa_restorer;
 #else
@@ -206,6 +206,13 @@ static void psx_posix_syscall_actor(int signum, siginfo_t *info, void *ignore) {
 	    __asm__ __volatile__("\npsx_restorer:\n\tli 0, 172\n\tsc\n");
