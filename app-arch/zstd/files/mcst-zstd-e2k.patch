         ptr += 8;
@@ -2446,6 +2458,7 @@ XXH64_finalize(xxh_u64 h64, const xxh_u8* ptr, size_t len, XXH_alignment align)
         h64 = XXH_rotl64(h64, 23) * XXH_PRIME64_2 + XXH_PRIME64_3;
         len -= 4;
     }
+#pragma loop count(3)
     while (len > 0) {
         h64 ^= (*ptr++) * XXH_PRIME64_5;
         h64 = XXH_rotl64(h64, 11) * XXH_PRIME64_1;
@@ -2478,7 +2491,11 @@ XXH64_endian_align(const xxh_u8* input, size_t len, xxh_u64 seed, XXH_alignment
         xxh_u64 v3 = seed + 0;
         xxh_u64 v4 = seed - XXH_PRIME64_1;
 
+#pragma loop count(1000)
         do {
+#if defined(__e2k__) && __iset__ < 5
+            __builtin_prefetch(input+192);
+#endif
             v1 = XXH64_round(v1, XXH_get64bits(input)); input+=8;
             v2 = XXH64_round(v2, XXH_get64bits(input)); input+=8;
             v3 = XXH64_round(v3, XXH_get64bits(input)); input+=8;
