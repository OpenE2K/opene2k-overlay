@@ -2401,7 +2408,11 @@ XXH_readLE64_align(const void* ptr, XXH_alignment align)
 
 static xxh_u64 XXH64_round(xxh_u64 acc, xxh_u64 input)
 {
+#ifndef __e2k__
     acc += input * XXH_PRIME64_2;
+#else
+    acc = __builtin_e2k_paddd(acc, input * XXH_PRIME64_2);
+#endif
     acc  = XXH_rotl64(acc, 31);
     acc *= XXH_PRIME64_1;
     return acc;
@@ -2433,6 +2444,7 @@ XXH64_finalize(xxh_u64 h64, const xxh_u8* ptr, size_t len, XXH_alignment align)
 {
