 #  define XXH_rotl32(x,r) _rotl(x,r)
 #  define XXH_rotl64(x,r) _rotl64(x,r)
+#elif defined(__e2k__)
+#  define XXH_rotl32(x,r) __builtin_e2k_scls(x,r)
