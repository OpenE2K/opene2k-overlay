# this stage3 is rebuilt from bootstrapped or previously built stage3
# targets v3 so it can run on newer machines
subarch: e2k
target: stage3
rel_type: 23.0-e2k
profile: opene2k:default/linux/e2k/23.0
version_stamp: 23.0-@TIMESTAMP@
snapshot_treeish: @TREEISH@
source_subpath: 23.0-e2k/stage3-e2k-23.0-@SEED_TIMESTAMP@
repos: /var/db/repos/opene2k
portage_confdir: /usr/share/catalyst/confdir/e2k-v3
portage_prefix: opene2k
